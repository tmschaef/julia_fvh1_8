(# Per-thread scratch + RNG for parallel mc3d \(no per-cell allocation\).) N
(mutable struct McScratch) N
(    lambda::Matrix{Float64}) N
(    lambda_t::Matrix{Float64}) N
(    delta_p::Matrix{Float64}) N
(    qnew_cube::Vector{Float64}) N
(    pcube1::Vector{Float64}) N
(    pcube2::Vector{Float64}) N
(    pcube3::Vector{Float64}) N
(    rng::Xoshiro) N
(end) N
() N
(function McScratch\(tid::Int\)) N
(    McScratch\() N
(        zeros\(Float64, 3, 3\),) N
(        zeros\(Float64, 3, 3\),) N
(        zeros\(Float64, 3, 3\),) N
(        zeros\(Float64, 8\),) N
(        zeros\(Float64, 8\),) N
(        zeros\(Float64, 8\),) N
(        zeros\(Float64, 8\),) N
(        Xoshiro\(123456 + tid * 100003\)) N
(    \)) N
(end) N
() N
(mutable struct McThreadPool) N
(    grid::McWork) N
(    scratch::Vector{McScratch}) N
(end) N
() N
(function McThreadPool\(\)) N
(    n = Threads.maxthreadid\(\)) N
(    McThreadPool\(McWork\(\), [McScratch\(tid\) for tid in 1:n]\)) N
(end) N
() N
(@inline mc_phase_count\(n::Int, parity::Int\) = \(n - parity + 1\) \303\267 2) N
() N
(# Per-thread Sweeps + PpmWork for parallel line sweeps \(sweepx/y/z\).) N
(mutable struct SweepThreadPool) N
(    sweeps::Vector{Sweeps}) N
(    work::Vector{PpmWork}) N
(end) N
() N
(function SweepThreadPool\(\)) N
(    n = Threads.maxthreadid\(\)) N
(    SweepThreadPool\([Sweeps\(\) for _ in 1:n], [PpmWork\(\) for _ in 1:n]\)) N
(end) N
() N
(function _build_pixky_trig\(\)) N
(    nk = jmax) N
(    cos_j = Matrix{Float64}\(undef, jmax, nk\)) N
(    sin_j = Matrix{Float64}\(undef, jmax, nk\)) N
(    sin_i = Matrix{Float64}\(undef, imax, nk\)) N
(    for in_ in 1:nk) N
(        for j in 1:jmax) N
(            ang = 2.0 * \317M-^@ * j * in_ / jmax) N
(            cos_j[j, in_] = cos\(ang\)) N
(            sin_j[j, in_] = sin\(ang\)) N
(        end) N
(        for i in 1:imax) N
(            sin_i[i, in_] = sin\(2.0 * \317M-^@ * \(i - 1\) * in_ / imax\)) N
(        end) N
(    end) N
