rm init.ps 
rm dtcon.ps
rm stress.ps
rm sweepx.ps
rm sweepy.ps 
rm sweepz.ps
rm mc3d.ps
rm prin.ps 
rm vhone.pdf
rm init.pdf
rm dtcon.pdf
rm stress.pdf
rm sweepx.pdf
rm sweepy.pdf
rm sweepz.pdf
rm mc3d.pdf
rm prin.pdf 
a2ps -1 -o ppmlr.ps    ppmlr.jl
a2ps -1 -o boundary.ps boundary.jl
a2ps -1 -o parabola.ps parabola.jl
a2ps -1 -o states.ps   states.jl
a2ps -1 -o evolve.ps   evolve.jl
a2ps -1 -o remap.ps    remap.jl
a2ps -1 -o vh1state.ps vh1state.jl
ps2pdf ppmlr.ps    
ps2pdf boundary.ps 
ps2pdf parabola.ps 
ps2pdf states.ps   
ps2pdf evolve.ps   
ps2pdf remap.ps
ps2pdf vh1state.ps
pdftk  ppmlr.pdf boundary.pdf  parabola.pdf  states.pdf  evolve.pdf  remap.pdf   vh1state.pdf output ppmlrmain.pdf
rm ppmlr.ps    
rm boundary.ps 
rm parabola.ps 
rm states.ps   
rm evolve.ps   
rm remap.ps   
rm ppmlr.pdf    
rm boundary.pdf 
rm parabola.pdf  
rm states.pdf   
rm evolve.pdf      
rm remap.pdf
rm vh1state.pdf
pdftk vhonemain.pdf ppmlrmain.pdf output vh1-all.pdf
rm vhonemain.pdf ppmlrmain.pdf
