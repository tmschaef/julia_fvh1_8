#!/bin/tcsh
a2ps -1 -o vhone.ps   vhone.jl
a2ps -1 -o init.ps    init.jl
a2ps -1 -o dtcon.ps   dtcon.jl
a2ps -1 -o stress.ps  stress.jl
a2ps -1 -o sweepx.ps  sweepx.jl
a2ps -1 -o sweepy.ps  sweepy.jl
a2ps -1 -o sweepz.ps  sweepz.jl
a2ps -1 -o mc3d.ps mc3d.jl
a2ps -1 -o prin.ps    prin.jl
ps2pdf vhone.ps
ps2pdf init.ps 
ps2pdf dtcon.ps
ps2pdf stress.ps
ps2pdf sweepx.ps
ps2pdf sweepy.ps 
ps2pdf sweepz.ps
ps2pdf mc3d.ps
ps2pdf prin.ps 
pdftk vhone.pdf init.pdf dtcon.pdf stress.pdf sweepx.pdf sweepy.pdf sweepz.pdf mc3d.pdf prin.pdf output vhonemain.pdf
